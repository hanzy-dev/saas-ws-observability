{
  "uid": "ws-hello-http-red",
  "title": "saas-ws-hello - HTTP RED",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["workspace", "hello", "http"],
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "refresh": 2,
        "query": "label_values(ws_hello_http_requests_total, route)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (RPS)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ws_hello_http_requests_total{route=~\"$route\"}[5m]))",
          "legendFormat": "rps"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (5xx)",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ws_hello_http_requests_total{status=~\"5..\",route=~\"$route\"}[5m]))",
          "legendFormat": "5xx rps"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error % (5xx)",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(ws_hello_http_requests_total{status=~\"5..\",route=~\"$route\"}[5m])) / sum(rate(ws_hello_http_requests_total{route=~\"$route\"}[5m])))"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false } },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency p50/p95/p99 (seconds)",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ws_hello_http_request_duration_seconds_bucket{route=~\"$route\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ws_hello_http_request_duration_seconds_bucket{route=~\"$route\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ws_hello_http_request_duration_seconds_bucket{route=~\"$route\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Top routes by request rate",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (route) (rate(ws_hello_http_requests_total[5m])))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    }
  ]
}